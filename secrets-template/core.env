# Core agent environment
# Copy to ../secrets/core.env and fill in values
# chmod 600 ../secrets/core.env

# LLM (Ollama or any OpenAI-compatible API)
MODEL=qwen2.5:7b
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama

# Security
API_SECRET=CHANGE_ME_RANDOM_32_CHARS
OWNER_ID=0

# Optional: Brave Search API key (leave empty to use DuckDuckGo)
BRAVE_API_KEY=

# Tuning
MAX_ITERATIONS=20
COMMAND_TIMEOUT=60
MAX_TOKENS=4096
