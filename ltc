#!/usr/bin/env bash
# ltc — LocalTaskClaw CLI
set -euo pipefail

INSTALL_DIR="$HOME/.localtaskclaw"
APP_DIR="$INSTALL_DIR/app"
VENV="$INSTALL_DIR/venv"
SECRETS="$INSTALL_DIR/app/secrets"
PORT="${LTC_PORT:-11387}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

die() { echo -e "${RED}error:${NC} $1" >&2; exit 1; }

# ── Helpers ──────────────────────────────────────────────────────────────────

_is_mac() { [[ "$(uname -s)" == "Darwin" ]]; }

_plist() { echo "$HOME/Library/LaunchAgents/io.localtaskclaw.${1}.plist"; }

_is_running() {
  local svc="${1:-core}"
  if _is_mac; then
    launchctl list "io.localtaskclaw.${svc}" &>/dev/null && return 0
  else
    systemctl --user is-active "localtaskclaw-${svc}" &>/dev/null && return 0
  fi
  # Fallback: check process
  pgrep -f "localtaskclaw.*${svc}" &>/dev/null
}

_health() {
  curl -sf "http://localhost:${PORT}/health" &>/dev/null
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_start() {
  echo -e "${BOLD}Starting LocalTaskClaw...${NC}"
  if _is_mac; then
    for svc in core bot; do
      local plist; plist=$(_plist "$svc")
      if [[ -f "$plist" ]]; then
        launchctl load "$plist" 2>/dev/null || true
        echo -e "  ${GREEN}+${NC} $svc"
      else
        echo -e "  ${YELLOW}!${NC} $svc — plist not found"
      fi
    done
  elif command -v systemctl &>/dev/null; then
    systemctl --user start localtaskclaw-core localtaskclaw-bot 2>/dev/null
    echo -e "  ${GREEN}+${NC} core + bot"
  else
    # nohup fallback
    cd "$APP_DIR/core"
    ENV_FILE="$SECRETS/core.env" \
      nohup "$VENV/bin/python" -m uvicorn api:app --host 0.0.0.0 --port "$PORT" \
      > /tmp/localtaskclaw-core.log 2>&1 &
    cd "$APP_DIR/bot"
    ENV_FILE="$SECRETS/bot.env" \
      nohup "$VENV/bin/python" main.py \
      > /tmp/localtaskclaw-bot.log 2>&1 &
    echo -e "  ${GREEN}+${NC} core + bot (nohup)"
  fi
  # Wait for health
  for _ in $(seq 1 15); do
    sleep 1
    if _health; then
      echo -e "${GREEN}Online${NC} — http://localhost:${PORT}/admin/"
      return
    fi
  done
  echo -e "${YELLOW}Started but health check timed out — check logs${NC}"
}

cmd_stop() {
  echo -e "${BOLD}Stopping LocalTaskClaw...${NC}"
  if _is_mac; then
    for svc in core bot; do
      local plist; plist=$(_plist "$svc")
      [[ -f "$plist" ]] && launchctl unload "$plist" 2>/dev/null || true
    done
  elif command -v systemctl &>/dev/null; then
    systemctl --user stop localtaskclaw-core localtaskclaw-bot 2>/dev/null || true
  fi
  # Kill any remaining processes
  pkill -f '\.localtaskclaw/.*main\.py' 2>/dev/null || true
  pkill -f '\.localtaskclaw/.*uvicorn' 2>/dev/null || true
  echo -e "${GREEN}Stopped${NC}"
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_status() {
  echo -e "${BOLD}LocalTaskClaw Status${NC}"
  echo ""

  # Core
  if _is_running core; then
    if _health; then
      local model
      model=$(curl -sf "http://localhost:${PORT}/health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('model','?'))" 2>/dev/null || echo "?")
      echo -e "  core    ${GREEN}running${NC}  port $PORT  model: $model"
    else
      echo -e "  core    ${YELLOW}process alive, not responding${NC}"
    fi
  else
    echo -e "  core    ${RED}stopped${NC}"
  fi

  # Bot
  if _is_running bot; then
    echo -e "  bot     ${GREEN}running${NC}"
  else
    echo -e "  bot     ${RED}stopped${NC}"
  fi

  # Version
  if [[ -d "$APP_DIR/.git" ]]; then
    local hash
    hash=$(cd "$APP_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "?")
    echo -e "\n  version ${DIM}$hash${NC}"
  fi

  echo ""
}

cmd_logs() {
  local source="${1:-core}"
  case "$source" in
    core|bot) ;;
    *) die "Unknown log source: $source (use 'core' or 'bot')" ;;
  esac
  local logfile="/tmp/localtaskclaw-${source}.log"
  if [[ -f "$logfile" ]]; then
    tail -f "$logfile"
  else
    # Try fetching from API
    if _health; then
      local secret=""
      if [[ -f "$SECRETS/core.env" ]]; then
        secret=$(grep '^API_SECRET=' "$SECRETS/core.env" 2>/dev/null | cut -d= -f2 || true)
      fi
      echo -e "${DIM}Streaming from API...${NC}"
      curl -sN "http://localhost:${PORT}/logs/tail?source=${source}&lines=100" \
        -H "X-Api-Key: ${secret}" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    for l in d.get('lines', []):
        print(l)
except: pass
" 2>/dev/null
      echo -e "\n${DIM}(Live streaming not available in CLI — use ltc open for live logs)${NC}"
    else
      die "No log file at $logfile and API is offline"
    fi
  fi
}

cmd_test() {
  local target="${1:-all}"
  [[ -d "$VENV" ]] || die "Venv not found at $VENV"

  # Ensure pytest is installed
  if ! "$VENV/bin/python" -m pytest --version &>/dev/null; then
    echo -e "${DIM}Installing pytest...${NC}"
    "$VENV/bin/pip" install -q pytest httpx 2>/dev/null
  fi

  echo -e "${BOLD}Running tests...${NC}\n"
  case "$target" in
    all)
      "$VENV/bin/python" -m pytest "$APP_DIR/tests/" -v -s --tb=short
      ;;
    kanban)
      "$VENV/bin/python" -m pytest "$APP_DIR/tests/test_kanban_e2e.py" -v -s --tb=short
      ;;
    seed)
      "$VENV/bin/python" -m pytest "$APP_DIR/tests/test_seed_e2e.py" -v -s --tb=short
      ;;
    *)
      # Try as a file path
      if [[ -f "$target" ]]; then
        "$VENV/bin/python" -m pytest "$target" -v -s --tb=short
      else
        die "Unknown test target: $target (use 'all', 'kanban', 'seed', or a file path)"
      fi
      ;;
  esac
}

cmd_seed() {
  [[ -d "$VENV" ]] || die "Venv not found"
  echo -e "${BOLD}Seeding demo data...${NC}\n"
  "$VENV/bin/python" "$APP_DIR/scripts/seed_kanban.py" "${@}"
}

cmd_update() {
  [[ -f "$APP_DIR/update.sh" ]] || die "update.sh not found"
  bash "$APP_DIR/update.sh" "${@}"
}

cmd_open() {
  local url="http://localhost:${PORT}/admin/"
  echo -e "Opening ${BOLD}$url${NC}"
  if _is_mac; then
    open "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "$url"
  fi
}

cmd_uninstall() {
  [[ -f "$APP_DIR/uninstall.sh" ]] || die "uninstall.sh not found"
  bash "$APP_DIR/uninstall.sh"
}

cmd_build() {
  [[ -d "$APP_DIR/frontend" ]] || die "frontend/ not found"
  echo -e "${BOLD}Building frontend...${NC}"
  cd "$APP_DIR/frontend"
  npm install --silent 2>/dev/null
  npm run build
  echo -e "${GREEN}Done${NC} — output in admin/"
}

cmd_help() {
  echo -e "${BOLD}ltc${NC} — LocalTaskClaw CLI"
  echo ""
  echo -e "  ${GREEN}ltc start${NC}              Start services"
  echo -e "  ${GREEN}ltc stop${NC}               Stop services"
  echo -e "  ${GREEN}ltc restart${NC}            Restart services"
  echo -e "  ${GREEN}ltc status${NC}             Show status"
  echo -e "  ${GREEN}ltc logs${NC} [core|bot]    Tail logs (default: core)"
  echo -e "  ${GREEN}ltc test${NC} [all|kanban|seed]  Run tests"
  echo -e "  ${GREEN}ltc seed${NC} [--reset]     Seed demo kanban data"
  echo -e "  ${GREEN}ltc update${NC}             Pull latest code & restart"
  echo -e "  ${GREEN}ltc build${NC}              Rebuild frontend"
  echo -e "  ${GREEN}ltc open${NC}               Open admin UI in browser"
  echo -e "  ${GREEN}ltc uninstall${NC}          Remove LocalTaskClaw"
  echo -e "  ${GREEN}ltc help${NC}               Show this help"
  echo ""
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  start)      cmd_start "$@" ;;
  stop)       cmd_stop "$@" ;;
  restart)    cmd_restart "$@" ;;
  status|st)  cmd_status "$@" ;;
  logs|log)   cmd_logs "$@" ;;
  test)       cmd_test "$@" ;;
  seed)       cmd_seed "$@" ;;
  update|up)  cmd_update "$@" ;;
  build)      cmd_build "$@" ;;
  open)       cmd_open "$@" ;;
  uninstall)  cmd_uninstall "$@" ;;
  help|-h|--help) cmd_help ;;
  *) echo -e "${RED}Unknown command:${NC} $cmd"; echo ""; cmd_help; exit 1 ;;
esac
